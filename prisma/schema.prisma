// Prisma schema for InvoFlow — invoicing & inventory management.
// Multi-tenant: every tenant-owned row carries an `organizationId` and all
// queries are scoped by it. See src/lib/auth.ts + src/lib/session.ts.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Direct (non-pooled) connection used by `prisma migrate`. If you don't use a
  // pooler, point this at the same URL as DATABASE_URL.
  directUrl = env("DIRECT_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum StockChangeType {
  INITIAL // opening stock
  PURCHASE // received new stock
  SALE // sold via invoice
  RETURN // customer return
  ADJUSTMENT // manual correction
  DAMAGE // write-off / loss
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DiscountType {
  NONE
  PERCENTAGE
  FIXED
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHECK
  OTHER
}

// ----------------------------------------------------------------------------
// Tenancy & auth
// ----------------------------------------------------------------------------

model Organization {
  id   String @id @default(cuid())
  name String

  // Company details used on invoice templates.
  email      String?
  phone      String?
  website    String?
  taxId      String?
  logoUrl    String?
  addressLine1 String?
  addressLine2 String?
  city       String?
  state      String?
  postalCode String?
  country    String?

  // Invoicing configuration.
  currency       String @default("USD")
  invoicePrefix  String @default("INV-")
  invoiceCounter Int    @default(0) // last issued sequence number
  defaultTaxRate Decimal @default(0) @db.Decimal(5, 2)

  users            User[]
  customers        Customer[]
  categories       Category[]
  products         Product[]
  invoices         Invoice[]
  payments         Payment[]
  stockAdjustments StockAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  name           String
  passwordHash   String
  role           UserRole @default(OWNER)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stockAdjustments StockAdjustment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

// ----------------------------------------------------------------------------
// Inventory
// ----------------------------------------------------------------------------

model Category {
  id             String  @id @default(cuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Product {
  id             String   @id @default(cuid())
  sku            String
  name           String
  description    String?
  categoryId     String?
  category       Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  unitPrice      Decimal @default(0) @db.Decimal(12, 2)
  costPrice      Decimal @default(0) @db.Decimal(12, 2)
  quantityOnHand Int     @default(0)
  reorderLevel   Int     @default(0)
  unitOfMeasure  String  @default("unit")
  taxRate        Decimal @default(0) @db.Decimal(5, 2) // percentage, e.g. 7.50

  isActive       Boolean @default(true)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  stockAdjustments StockAdjustment[]
  lineItems        InvoiceLineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([categoryId])
}

model StockAdjustment {
  id               String          @id @default(cuid())
  productId        String
  product          Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  type             StockChangeType
  quantityChange   Int // signed: +received / -sold
  previousQuantity Int
  newQuantity      Int
  reason           String?
  reference        String? // e.g. invoice number that caused the change

  createdById      String?
  createdBy        User?           @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt        DateTime        @default(now())

  @@index([organizationId])
  @@index([productId])
}

// ----------------------------------------------------------------------------
// Customers & invoicing
// ----------------------------------------------------------------------------

model Customer {
  id             String  @id @default(cuid())
  name           String
  email          String?
  phone          String?

  billingAddressLine1 String?
  billingAddressLine2 String?
  billingCity         String?
  billingState        String?
  billingPostalCode   String?
  billingCountry      String?

  shippingAddressLine1 String?
  shippingAddressLine2 String?
  shippingCity         String?
  shippingState        String?
  shippingPostalCode   String?
  shippingCountry      String?

  notes String?

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  invoices Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Invoice {
  id             String        @id @default(cuid())
  number         String
  status         InvoiceStatus @default(DRAFT)

  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)

  organizationId String
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  issueDate    DateTime  @default(now())
  dueDate      DateTime
  paymentTerms String?
  notes        String?
  terms        String?

  discountType  DiscountType @default(NONE)
  discountValue Decimal      @default(0) @db.Decimal(12, 2)

  subtotal      Decimal @default(0) @db.Decimal(12, 2)
  discountTotal Decimal @default(0) @db.Decimal(12, 2)
  taxTotal      Decimal @default(0) @db.Decimal(12, 2)
  total         Decimal @default(0) @db.Decimal(12, 2)
  amountPaid    Decimal @default(0) @db.Decimal(12, 2)

  currency String @default("USD")

  // Set when the invoice transitions out of DRAFT and stock is deducted.
  finalizedAt DateTime?

  lineItems InvoiceLineItem[]
  payments  Payment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@index([customerId])
  @@index([status])
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)

  lineSubtotal Decimal @db.Decimal(12, 2)
  lineTax      Decimal @db.Decimal(12, 2)
  lineTotal    Decimal @db.Decimal(12, 2)

  sortOrder Int @default(0)

  @@index([invoiceId])
  @@index([productId])
}

model Payment {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod @default(OTHER)
  reference String?
  note      String?
  paidAt    DateTime      @default(now())

  createdAt DateTime @default(now())

  @@index([organizationId])
  @@index([invoiceId])
}
