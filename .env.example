# ----------------------------------------------------------------------------
# Database (PostgreSQL)
# ----------------------------------------------------------------------------
# Any Postgres works. Quick options:
#   - Supabase:  Project Settings -> Database -> Connection string (URI)
#   - Neon:      Dashboard -> Connection Details
#   - Local:     postgresql://postgres:postgres@localhost:5432/invoflow
#
# If your provider uses a connection pooler (e.g. Supabase/Neon), set
# DATABASE_URL to the pooled URL and DIRECT_URL to the direct (non-pooled) URL
# so that `prisma migrate` works correctly. If you don't have a pooler, set
# both to the same value.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/invoflow?schema=public"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/invoflow?schema=public"

# ----------------------------------------------------------------------------
# NextAuth / Auth.js
# ----------------------------------------------------------------------------
# Generate a secret with:  openssl rand -base64 32
AUTH_SECRET="replace-me-with-a-long-random-string"

# Base URL of the app (only needed in production / behind a proxy).
# AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"
